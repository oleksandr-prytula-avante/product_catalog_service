{
  "name": "Product Catalog Service Dev Container",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "app-dev",
  "runServices": ["app-dev", "atlas-migrate"],
  "workspaceFolder": "/usr/src/app",
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.Go"
      ],
      "settings": {
        "go.toolsManagement.autoUpdate": true
      }
    }
  }
}